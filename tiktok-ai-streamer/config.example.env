# Kopyala: cp config.example.env .env  ve doldur. .env'i ASLA paylaşma/commit etme.

# Senin TikTok kullanıcı adın (canlı sohbeti bu yayından okunur), @ olmadan
TIKTOK_USERNAME=senin_kullanici_adin

# Yayın anahtarı (TikTok LIVE Producer'dan ya da ajanstan). Her yayında değişir.
RTMP_URL=rtmp://...           # Server URL
STREAM_KEY=...                # Stream Key

# Ücretsiz AI beyin (Groq önerilir: console.groq.com → ücretsiz API key)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_...
LLM_MODEL=llama-3.3-70b-versatile

# Avatarın kişiliği (kim, nasıl konuşur)
PERSONA=Sen Cyber adında, neşeli ve sıcak bir sanal yayıncısın. İzleyici mesajlarına Türkçe, kısa (max 2 cümle), samimi ve eğlenceli cevap verirsin. Küfür/yetişkin içerik yok.

# Avatar video dosyası (döngüye girecek kısa mp4). Yoksa basit bir görsel.
AVATAR_VIDEO=avatar.mp4

# Ses (edge-tts) — Türkçe kadın sesi
TTS_VOICE=tr-TR-EmelNeural
